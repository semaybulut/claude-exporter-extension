{
  "manifest_version": 3,
  "name": "Claude Exporter",
  "version": "1.0.0",
  "description": "Export Claude conversations as Markdown with one click.",
  "permissions": ["clipboardWrite", "clipboardRead", "scripting"],,
  "host_permissions": ["https://claude.ai/*"],
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
